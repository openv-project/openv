{
  "name": "filesystem",
  "version": "0.1.0",
  "description": "Base filesystem layout package (Arch-inspired, partial)",
  "directories": [
    "/boot",
    "/dev",
    "/etc",
    "/home",
    "/mnt",
    "/opt",
    "/root",
    "/run",
    "/srv",
    "/srv/openv-webos",
    "/proc",
    "/usr",
    "/usr/bin",
    "/usr/include",
    "/usr/lib",
    "/usr/local",
    "/usr/local/bin",
    "/usr/local/etc",
    "/usr/local/games",
    "/usr/local/include",
    "/usr/local/lib",
    "/usr/local/man",
    "/usr/local/sbin",
    "/usr/local/share",
    "/usr/local/share/man",
    "/usr/local/src",
    "/usr/share",
    "/usr/src",
    "/var",
    "/var/cache",
    "/var/empty",
    "/var/lib",
    "/var/lib/misc",
    "/var/local",
    "/var/log",
    "/var/opt",
    "/var/tmp",
    "/run/lock"
  ],
  "files": [],
  "symlinks": [
    { "path": "/bin", "target": "/usr/bin" },
    { "path": "/sbin", "target": "/usr/bin" },
    { "path": "/lib", "target": "/usr/lib" },
    { "path": "/lib64", "target": "/usr/lib" },
    { "path": "/usr/sbin", "target": "/usr/bin" },
    { "path": "/usr/lib64", "target": "/usr/lib" },
    { "path": "/var/run", "target": "/run" },
    { "path": "/var/lock", "target": "/run/lock" }
  ]
}
