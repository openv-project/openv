{
    "name": "openv-rewrite",
    "lockfileVersion": 3,
    "requires": true,
    "packages": {
        "": {
            "license": "MIT",
            "workspaces": [
                "packages/*"
            ]
        },
        "node_modules/@openv-project/openv-api": {
            "resolved": "packages/openv-api",
            "link": true
        },
        "node_modules/@openv-project/openv-core": {
            "resolved": "packages/openv-core",
            "link": true
        },
        "packages/openv-api": {
            "name": "@openv-project/openv-api",
            "version": "0.1.0",
            "license": "MIT"
        },
        "packages/openv-core": {
            "name": "@openv-project/openv-core",
            "version": "0.1.0",
            "license": "MIT",
            "dependencies": {
                "@openv-project/openv-api": "^0.1.0"
            }
        }
    }
}
